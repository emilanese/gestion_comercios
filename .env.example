# ─────────────────────────────────────────────────────────────────────────────
# AVANTI — Variables de entorno
#
# Copiar a .env y completar los valores de producción.
# NUNCA commitear el .env con secrets reales.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Backend Go ───────────────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=postgres://comercios_user:comercios_pass@localhost:5432/comercios_db?sslmode=disable
REDIS_URL=redis://localhost:6379

# Cambiar por un secreto seguro en producción (mínimo 32 chars, aleatorio)
# Ejemplo: openssl rand -hex 32
JWT_SECRET=cambia-esto-en-produccion

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=comercios_user
POSTGRES_PASSWORD=comercios_pass
POSTGRES_DB=comercios_db

# ─── Next.js Web App (Desarrollo local) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ─── Next.js Web App (Producción VPS) ────────────────────────────────────────
# Descomentar en producción:
# NEXT_PUBLIC_API_URL=https://api.avanti-retail.cloud
# NEXT_PUBLIC_WS_URL=wss://api.avanti-retail.cloud/ws

# ─── Expo Mobile App (Desarrollo local) ──────────────────────────────────────
# Usar la IP de tu máquina en la red local (no localhost — el dispositivo es externo)
EXPO_PUBLIC_API_URL=http://192.168.1.X:8080
EXPO_PUBLIC_WS_URL=ws://192.168.1.X:8080/ws

# ─── Expo Mobile App (Producción) ────────────────────────────────────────────
# Descomentar en producción:
# EXPO_PUBLIC_API_URL=https://api.avanti-retail.cloud
# EXPO_PUBLIC_WS_URL=wss://api.avanti-retail.cloud/ws

# ─── Dominios (para referencia) ──────────────────────────────────────────────
# avanti-retail.cloud         → Landing Page
# hub.avanti-retail.cloud     → AVANTI HUB (ADMIN/ENCARGADO)
# pos.avanti-retail.cloud     → AVANTI POS Web (CAJERO en navegador)
# api.avanti-retail.cloud     → Gestor Cloud Go (REST + WSS)
