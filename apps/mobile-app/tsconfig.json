{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/types/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
