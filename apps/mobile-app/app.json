{
  "expo": {
    "name": "AVANTI POS",
    "slug": "avanti-pos",
    "version": "1.0.0",
    "scheme": "avanti",
    "orientation": "portrait",
    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTabletMode": false,
      "bundleIdentifier": "cloud.avantiretail.pos"
    },

    "android": {
      "package": "cloud.avantiretail.pos",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8"
      }
    },

    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos acceso a la cámara para escanear códigos de barras y QR de enrolamiento"
        }
      ]
    ]
  }
}
